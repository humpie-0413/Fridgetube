# === FridgeTube 환경변수 ===
# 이 파일을 .env.local로 복사하고 값을 채우세요.
# cp .env.example .env.local

# --- YouTube Data API v3 ---
# https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# --- Google Gemini ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- PostgreSQL (Neon Free) ---
# https://neon.tech → 프로젝트 생성 후 Connection string 복사
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?sslmode=require

# --- Redis (Upstash Free) ---
# https://upstash.com → Redis 생성 후 REST URL 복사
REDIS_URL=redis://default:password@host:port

# --- Sentry (에러 모니터링) ---
# https://sentry.io → 프로젝트 생성 후 DSN 복사
SENTRY_DSN=

# --- Frontend → Backend 연결 ---
# 로컬 개발: http://localhost:8000
# 프로덕션: https://your-app.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- 기타 ---
# JWT 시크릿 (MVP에서는 인증 미구현이므로 임시값)
JWT_SECRET=dev-secret-change-in-production
# 환경
ENVIRONMENT=development
